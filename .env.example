# ── Xero service v2 — required env vars ──────────────────────────────────────
# Copy to .env and fill in the blanks.

# ── Postgres (local docker-compose defaults) ─────────────────────────────────
DATABASE_URL=postgresql://xero_user:xero_dev_password@localhost:5434/xero_v2

# ── Redis (local docker-compose defaults) ────────────────────────────────────
REDIS_URL=redis://localhost:6381/0

# PKCE OAuth Credentials (single OAuth app for all organizations)
# Users authenticate and grant access to their organizations
XERO_CONNECTION_TYPE=pkce
XERO_CLIENT_ID=your_xero_client_id
XERO_CLIENT_SECRET=your_xero_client_secret
XERO_REDIRECT_URI=http://localhost:5002/api/xero/callback

# Custom Connection mode (client_credentials) for one Xero organization.
# Set XERO_CONNECTION_TYPE=custom and fill either XERO_CC_* or XERO_ORG_N_*.
# Use XERO_CUSTOM_CONNECTION_ORG_INDEX to select numbered XERO_ORG_N_* values.
# Do not commit real client secrets.
# XERO_CUSTOM_CONNECTION_ORG_INDEX=1
# XERO_CC_TENANT_NAME=Aquatiq Australia Pty Ltd
# XERO_CC_TENANT_ID=00000000-0000-0000-0000-000000000000
# XERO_CC_CLIENT_ID=your_custom_connection_client_id
# XERO_CC_CLIENT_SECRET=your_custom_connection_client_secret

# ── HTTP server ───────────────────────────────────────────────────────────────
XERO_HTTP_BIND=0.0.0.0:5002

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info,xero_cli=debug,xero_state=debug
