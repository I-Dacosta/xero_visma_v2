# ── xero_service_v2 — environment (stateless raw → GCS uploader) ──────────────
# Copy to .env and fill in the blanks. NEVER commit real secrets.
#
# This service is a one-shot CLI job: it fetches raw Xero pages and writes them
# verbatim to GCS, then exits. No Postgres, Redis, BigQuery, or HTTP server, and
# custom-connection (client_credentials) auth only — no PKCE.

# ── Auth — custom connection only ─────────────────────────────────────────────
# client_credentials per Xero organisation. Mandatory; PKCE is not supported.
XERO_CONNECTION_TYPE=custom

# Numbered orgs (preferred for a multi-org fleet). One block per organisation,
# N = 1, 2, 3, …. Fill the secret from your secret manager — do not commit it.
XERO_ORG_1_NAME=Aquatiq Australia Pty Ltd
XERO_ORG_1_TENANT_ID=00000000-0000-0000-0000-000000000000
XERO_ORG_1_CLIENT_ID=your_org1_custom_connection_client_id
XERO_ORG_1_CLIENT_SECRET=your_org1_custom_connection_client_secret
# XERO_ORG_2_NAME=...
# XERO_ORG_2_TENANT_ID=...
# XERO_ORG_2_CLIENT_ID=...
# XERO_ORG_2_CLIENT_SECRET=...

# Which numbered org is "primary" (used when a single-org context is needed).
# XERO_CUSTOM_CONNECTION_ORG_INDEX=1

# Single-org alternative to the numbered blocks (XERO_CC_* takes the same role
# as XERO_ORG_1_*). Use one style or the other, not both.
# XERO_CC_TENANT_NAME=Aquatiq Australia Pty Ltd
# XERO_CC_TENANT_ID=00000000-0000-0000-0000-000000000000
# XERO_CC_CLIENT_ID=your_custom_connection_client_id
# XERO_CC_CLIENT_SECRET=your_custom_connection_client_secret

# Space-separated OAuth scopes granted to the custom connection.
XERO_SCOPES=accounting.transactions.read accounting.contacts.read accounting.settings.read accounting.reports.read accounting.budgets.read accounting.journals.read

# ── GCS destination ───────────────────────────────────────────────────────────
# Bucket per environment simplifies IAM + lifecycle (xero-raw-dev / xero-raw-prod).
GCS_BUCKET=xero-raw-dev
# Key prefix for raw objects (default raw/xero). Manifests are written OUTSIDE
# this prefix, under _manifests/xero/…
GCS_PREFIX=raw/xero
# Path to the GCS service-account JSON. The SA needs roles/storage.objectCreator
# (and objectViewer for healthcheck --check-bucket) on GCS_BUCKET.
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcs-sa.json

# ── Sync tuning ───────────────────────────────────────────────────────────────
# Incremental modified-window look-back in days.
SYNC_WINDOW_DAYS=3
# rolling-full (tight) window — weekly via --full-with-window.
SYNC_ROLLING_FULL_TIGHT_DAYS=30
# rolling-full (wide) window — monthly via --business-from/--business-to.
SYNC_ROLLING_FULL_WIDE_DAYS=90
# Max concurrent (tenant, entity) tasks. Clamped to 1..=6 (Xero per-tenant ceiling).
SYNC_MAX_CONCURRENT=6

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info,xero_cli=info,xero_sync=info,xero_client=info,xero_gcs=info,xero_auth=info

# ── Local docker-compose only ─────────────────────────────────────────────────
# Host path to the GCS SA JSON bind-mounted into the container at
# /secrets/gcs-sa.json (must match GOOGLE_APPLICATION_CREDENTIALS above). Only
# needed for real (non-dry-run) uploads via docker compose.
# GCS_SA_JSON=./gcs-sa.json
