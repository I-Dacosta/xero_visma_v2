config {
  type: "table",
  schema: "dw_1_silver_excel",
  name: "seed_company_account_mapping",
  description: "Exact company-scoped account mapping extracted from Group mapping (kun NO, SE, DK).xlsx. Used as the primary account-to-group bridge before generic fallbacks.",
  tags: ["seed", "silver", "excel", "finance", "reference"]
}

-- Source: Group mapping (kun NO, SE, DK).xlsx
-- Sheet: NO
-- Rule: exact organization_name + local_account_code -> mapped_account_code_3

