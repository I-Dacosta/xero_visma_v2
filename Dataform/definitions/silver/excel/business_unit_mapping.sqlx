    CAST(NULL AS STRING),
    '33f319b9-4d57-11ee-960c-025417856183|02',
    'AHS',
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    'AQUATIQ_FOOD_FACTORY_AS',
    'Aquatiq',
    DATE '1900-01-01',
    CAST(NULL AS DATE)
  ),
  STRUCT(
    '9b1fa69b-5568-11ee-960c-025417856183',
    'Consult AS',
    CAST(NULL AS STRING),
    '33f319b9-4d57-11ee-960c-025417856183|03',
    'Consult',
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    'CONSULT_AS',
    'Aquatiq',
    DATE '1900-01-01',
    CAST(NULL AS DATE)
  ),
  STRUCT(
    'bb6c024e-5567-11ee-960c-025417856183',
    'Aquatiq Sense AS',
    CAST(NULL AS STRING),
    '33f319b9-4d57-11ee-960c-025417856183|04',
    'FT&A',
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    'AQUATIQ_SENSE_AS',
    'Aquatiq',
    DATE '1900-01-01',
    CAST(NULL AS DATE)
  ),

  -- Aquatiq AS after the 2026-01-01 reorganisation: BU driven by raw Visma subaccount segment 2
  STRUCT(
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    '0',
    '33f319b9-4d57-11ee-960c-025417856183|00',
    'Aquatiq AS',
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    'AQUATIQ_AS',
    'Aquatiq',
    DATE '2026-01-01',
    CAST(NULL AS DATE)
  ),
  STRUCT(
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    '1',
    '33f319b9-4d57-11ee-960c-025417856183|01',
    'Chemistry',
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    'AQUATIQ_AS',
    'Aquatiq',
    DATE '2026-01-01',
    CAST(NULL AS DATE)
  ),
  STRUCT(
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    '2',
    '33f319b9-4d57-11ee-960c-025417856183|02',
    'AHS',
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    'AQUATIQ_AS',
    'Aquatiq',
    DATE '2026-01-01',
    CAST(NULL AS DATE)
  ),
  STRUCT(
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    '3',
    '33f319b9-4d57-11ee-960c-025417856183|03',
    'Consult',
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    'AQUATIQ_AS',
    'Aquatiq',
    DATE '2026-01-01',
    CAST(NULL AS DATE)
  ),
  STRUCT(
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    '4',
    '33f319b9-4d57-11ee-960c-025417856183|04',
    'FT&A',
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    'AQUATIQ_AS',
    'Aquatiq',
    DATE '2026-01-01',
    CAST(NULL AS DATE)
  ),
  STRUCT(
    '33f319b9-4d57-11ee-960c-025417856183',
    'Aquatiq AS',
    '6',
    '33f319b9-4d57-11ee-960c-025417856183|06',
