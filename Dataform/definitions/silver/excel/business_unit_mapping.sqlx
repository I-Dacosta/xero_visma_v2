  -- Historical standalone tenants that roll into canonical Aquatiq AS BUs.
  -- These tenants still emit post-2025 data with local segment-2 department/service
  -- codes, but reporting BU remains the same canonical Aquatiq AS BU.
  STRUCT(
    '61320c0a-102d-11ee-a0e0-0693d8a7c3dd',
    'Aquatiq Hygiene Systems AS',
    CAST(NULL AS STRING),
    '33f319b9-4d57-11ee-960c-025417856183|02',
