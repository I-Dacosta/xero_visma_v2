config {
  type: "view",
  schema: "dw_1_silver_visma",
  name: "fact_inventory_issue",
  description: "Inventory issue headers filtered from the unified inventory movement fact.",
  tags: ["silver", "visma", "fact", "inventory", "issue"]
}

SELECT *
FROM ${ref("dw_1_silver_visma", "fact_inventory_movement")}
WHERE movement_type = 'ISSUE'
