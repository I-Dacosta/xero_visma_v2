config {
  type: "view",
  schema: "dw_1_silver_visma",
  name: "fact_inventory_receipt_line",
  description: "Inventory receipt lines filtered from the unified inventory movement line fact.",
  tags: ["silver", "visma", "fact", "inventory", "receipt"]
}

SELECT *
FROM ${ref("dw_1_silver_visma", "fact_inventory_movement_line")}
WHERE movement_type = 'RECEIPT'
