config {
  type: "table",
  schema: "ods_xero_1",
  name: "dim_user",
  description: "ODS Xero L1 (harmonized): Xero users. System-login concept distinct from Visma dim_employee — pass-through of ods_xero_0.dim_user plus source_system tag.",
  tags: ["ods", "xero", "l1", "dimension"],
  assertions: { nonNull: ["user_key", "tenant_id", "user_id"], uniqueKey: ["user_key"] }
}

SELECT
  *,
  'xero' AS source_system
FROM ${ref("ods_xero_0", "dim_user")}
