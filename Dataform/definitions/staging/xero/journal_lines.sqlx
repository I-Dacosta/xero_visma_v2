config {
  type: "declaration",
  schema: "staging_xero",
  name: "journal_lines",
  description: "Staging: Xero GL journal posting lines. One row per tenant_id + journal_id + journal_line_id (JournalLineID is a real native Xero field — unlike manual_journal_lines, no synthesized-key risk). net_amount is the balancing GL measure (verified 100% debits=credits); gross_amount double-counts tax on the origin line and must not be used for balance checks. Populated outside Dataform by the Python ETL (etl/xero/journals.py)."
}
