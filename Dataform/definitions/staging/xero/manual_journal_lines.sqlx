config {
  type: "declaration",
  schema: "staging_xero",
  name: "manual_journal_lines",
  description: "Staging: Xero manual journal lines (signed GL postings; debit positive / credit negative). NO LineItemID in the Xero payload. One row per journal line. Carries up to 2 tracking category/option pairs. Populated outside Dataform by the Python ETL."
}
