config {
  type: "declaration",
  schema: "staging_xero",
  name: "report_snapshots",
  description: "Staging: Xero Reports API snapshot headers (balance sheet, bank/budget/executive summary, P&L, trial balance). One row per (tenant_id, report kind, run) — NOT one row per entity; a re-run for the same date window is a new snapshot, never an update. Populated outside Dataform by etl/xero/reports.py."
