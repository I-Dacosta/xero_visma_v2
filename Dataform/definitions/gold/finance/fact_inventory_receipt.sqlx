config {
  type: "view",
  schema: "dw_1_gold_finance",
  name: "fact_inventory_receipt",
  description: "Inventory receipt header fact filtered from the unified inventory movement fact.",
  tags: ["gold", "finance", "fact", "inventory", "receipt"]
}

SELECT *
FROM ${ref("dw_1_gold_finance", "fact_inventory_movement")}
WHERE movement_type = 'RECEIPT'
