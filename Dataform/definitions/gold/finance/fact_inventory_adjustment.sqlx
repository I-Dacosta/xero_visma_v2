config {
  type: "view",
  schema: "dw_1_gold_finance",
  name: "fact_inventory_adjustment",
  description: "Inventory adjustment header fact filtered from the unified inventory movement fact.",
  tags: ["gold", "finance", "fact", "inventory", "adjustment"]
}

SELECT *
FROM ${ref("dw_1_gold_finance", "fact_inventory_movement")}
WHERE movement_type = 'ADJUSTMENT'
