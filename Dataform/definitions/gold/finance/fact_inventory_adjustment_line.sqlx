config {
  type: "view",
  schema: "dw_1_gold_finance",
  name: "fact_inventory_adjustment_line",
  description: "Inventory adjustment line fact filtered from the unified inventory movement line fact.",
  tags: ["gold", "finance", "fact", "inventory", "adjustment"]
}

SELECT *
FROM ${ref("dw_1_gold_finance", "fact_inventory_movement_line")}
WHERE movement_type = 'ADJUSTMENT'
