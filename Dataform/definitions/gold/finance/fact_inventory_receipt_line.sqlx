config {
  type: "view",
  schema: "dw_1_gold_finance",
  name: "fact_inventory_receipt_line",
  description: "Inventory receipt line fact filtered from the unified inventory movement line fact.",
  tags: ["gold", "finance", "fact", "inventory", "receipt"]
}

SELECT *
FROM ${ref("dw_1_gold_finance", "fact_inventory_movement_line")}
WHERE movement_type = 'RECEIPT'
